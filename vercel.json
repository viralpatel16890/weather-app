{
  "rootDirectory": "frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/weather-dashboard/browser",
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "https://your-app.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api-proxy).*)",
      "destination": "/index.html"
    }
  ]
}
